# Copy to .env.production.gpu on the GPU EC2 host (same directory as docker-compose.gpu.prod.yaml).
# Replace WEB_PRIVATE_IP with the web/app instance private IP (or use VPC DNS).
# Never commit real credentials.

# --- Reach web tier services over the VPC ---
DATABASE_URL=
REDIS_URL=

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=
S3_SECURE=

# Ollama in this compose stack (GPU host)
OLLAMA_BASE_URL=
OLLAMA_MODEL=

SECRET_KEY=
# OpenAI (optional):
# OPENAI_API_KEY=

# Root-level pointers. Copy real env files on servers under AGT_platform/ (never commit secrets).

# --- Web / app EC2 (.env.production next to docker-compose.web.prod.yaml) ---
# FRONTEND_BASE_URL=
# CORS_ORIGINS=
# DATABASE_URL=
# REDIS_URL=
# S3_* for MinIO on same host (see backend ReadMe / existing docs)

# --- Split deploy (GitHub Actions) ---
# DEPLOY_STACK=          # repository secret; omit or monolith for legacy single host
# GPU_SERVER_HOST=   # optional secret; GPU job runs only when set with DEPLOY_STACK=split

# --- GPU EC2 ---
# Copy AGT_platform/env.production.gpu.example → .env.production.gpu

# --- Cloudflare Pages (build env) ---
# VITE_API_BASE=

